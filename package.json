{
  "name": "mzdocs-pro",
  "version": "11.0.0",
  "description": "MzDocs Pro v11 — Documentos profissionais com IA para Moçambique",
  "main": "index.html",
  "homepage": "./",
  "scripts": {
    "dev": "vercel dev",
    "build": "node scripts/inject-version.js",
    "start": "vercel dev",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:auth": "jest tests/auth.test.js",
    "lint": "echo 'Linting not configured yet'"
  },
  "keywords": [
    "pwa",
    "ai",
    "documents",
    "mozambique"
  ],
  "author": "MzDocs Pro",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/functions": "^3.7.2",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "assets/js/**/*.js",
      "!assets/js/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
