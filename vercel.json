{
  "version": 2,
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/cleanup-temp-accounts",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/misc?action=blog-cron",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/generate-document.js": {
      "maxDuration": 60
    },
    "api/extract-template.js": {
      "maxDuration": 60
    },
    "api/verify-credits.js": {
      "maxDuration": 10
    },
    "api/deduct-credit.js": {
      "maxDuration": 10
    },
    "api/process-payment.js": {
      "maxDuration": 30
    },
    "api/delete-temp-account.js": {
      "maxDuration": 10
    },
    "api/cleanup-temp-accounts.js": {
      "maxDuration": 30
    },
    "api/auth/index.js": {
      "maxDuration": 30
    },
    "api/admin/index.js": {
      "maxDuration": 30
    },
    "api/misc.js": {
      "maxDuration": 30
    },
    "api/partners.js": {
      "maxDuration": 15
    },
    "api/convert.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/config",
      "destination": "/api/misc"
    },
    {
      "source": "/api/ocr-analyze",
      "destination": "/api/misc"
    },
    {
      "source": "/api/legal-search",
      "destination": "/api/misc"
    },
    {
      "source": "/api/verify-receipt",
      "destination": "/api/misc"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/misc?_a=sitemap.xml"
    },
    {
      "source": "/api/page-view",
      "destination": "/api/misc?_a=page-view"
    },
    {
      "source": "/api/admin/stats",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/settings",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/audit-log",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/delete-user",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/analytics",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/affiliate/:action",
      "destination": "/api/misc?_ns=affiliate&_a=:action"
    },
    {
      "source": "/api/admin/static-pages",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/documents",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/feedback",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/:action",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/auth/:action",
      "destination": "/api/auth/index"
    },
    {
      "source": "/api/templates/:action",
      "destination": "/api/misc?_ns=templates&_a=:action"
    },
    {
      "source": "/api/templates",
      "destination": "/api/misc?_ns=templates&_a=list"
    },
    {
      "source": "/api/partners",
      "destination": "/api/partners"
    },
    {
      "source": "/api/partners/:action",
      "destination": "/api/partners?action=:action"
    },
    {
      "source": "/api/convert",
      "destination": "/api/convert"
    },
    {
      "source": "/parceiros",
      "destination": "/parceiros.html"
    },
    {
      "source": "/admin-parceiros",
      "destination": "/admin-parceiros.html"
    },
    {
      "source": "/api/templates/gallery",
      "destination": "/api/misc?_ns=templates&_a=gallery"
    },
    {
      "source": "/api/templates/mine",
      "destination": "/api/misc?_ns=templates&_a=mine"
    },
    {
      "source": "/api/templates/saved",
      "destination": "/api/misc?_ns=templates&_a=saved"
    },
    {
      "source": "/api/templates/save",
      "destination": "/api/misc?_ns=templates&_a=save"
    },
    {
      "source": "/api/templates/use",
      "destination": "/api/misc?_ns=templates&_a=use"
    },
    {
      "source": "/api/templates/report",
      "destination": "/api/misc?_ns=templates&_a=report"
    },
    {
      "source": "/api/templates/share-token",
      "destination": "/api/misc?_ns=templates&_a=share-token"
    },
    {
      "source": "/api/templates/by-token",
      "destination": "/api/misc?_ns=templates&_a=by-token"
    },
    {
      "source": "/api/templates/delete",
      "destination": "/api/misc?_ns=templates&_a=delete"
    },
    {
      "source": "/api/admin/templates",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/template-approve",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/template-reject",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/template-feature",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/template-type",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/template-edit",
      "destination": "/api/admin/index"
    },
    {
      "source": "/api/admin/ai-providers",
      "destination": "/api/admin/index"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "redirects": [
    {
      "source": "/pages",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/pages/",
      "destination": "/blog",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net https://storage.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://www.clarity.ms https://scripts.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.supabase.co https://www.google-analytics.com https://www.googletagmanager.com https://www.facebook.com https://c.clarity.ms https://*.bing.com; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; connect-src 'self' https://api.cloudconvert.com https://storage.cloudconvert.com data: blob: https://*.supabase.co wss://*.supabase.co https://api.groq.com https://generativelanguage.googleapis.com https://openrouter.ai https://api.cerebras.ai https://integrate.api.nvidia.com https://api.anthropic.com https://cdn.jsdelivr.net https://storage.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com https://fonts.gstatic.com https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com https://www.facebook.com https://www.clarity.ms https://*.clarity.ms; worker-src 'self' blob: https://cdn.jsdelivr.net; frame-src 'self' blob:; media-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self';"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/assets/(.*)\\.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/pages/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, stale-while-revalidate=604800"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    },
    {
      "source": "/pages/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, stale-while-revalidate=604800"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "buildCommand": "node scripts/inject-version.js",
  "installCommand": "npm install",
  "cleanUrls": true,
  "env": {
    "SITE_URL": "https://mzdocs.co.mz"
  }
}
