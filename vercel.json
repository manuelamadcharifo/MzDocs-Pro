{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/sw.js",
      "headers": { "Cache-Control": "public, max-age=0", "Content-Type": "application/javascript; charset=utf-8" },
      "dest": "/dist/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": { "Content-Type": "application/json; charset=utf-8" },
      "dest": "/dist/manifest.json"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/(?!api/|assets/|.js$|.css$|.png$|.json$)(.*)",
      "dest": "/dist/index.html"
    }
  ]
}