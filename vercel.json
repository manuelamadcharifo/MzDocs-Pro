{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": "dist",

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/public.js",
      "dest": "/dist/public.js"
    },
    {
      "src": "/sw.js",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/dist/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/json"
      },
      "dest": "/dist/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}