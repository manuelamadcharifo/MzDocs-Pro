{
  "version": 2,
  "buildCommand": "echo 'Static PWA - no build required'",
  "outputDirectory": ".",
  "public": true,
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "OPENROUTER_API_KEY": "@openrouter_api_key"
  },
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
